# Skopiuj jako plik .env i uzupełnij klucz z Supabase → Settings → Project API → anon public
VITE_SUPABASE_URL=https://xtkzubyrxcngzwlykzup.supabase.co
VITE_SUPABASE_ANON_KEY=

# true = wymagane logowanie; false lub brak = aplikacja widoczna dla wszystkich (anon / stare RLS).
# VITE_REQUIRE_AUTH=true
#
# Opcjonalnie: pełny URL strony logowania (ten sam co domena Vercela). Musi być dopisany w Supabase
# → Authentication → URL Configuration → Redirect URLs (np. https://twoja-app.vercel.app/ ).
# VITE_AUTH_REDIRECT_URL=https://twoja-app.vercel.app/
#
# Deploy (Vercel): ustaw VITE_REQUIRE_AUTH=true oraz VITE_SUPABASE_URL i VITE_SUPABASE_ANON_KEY
# w Project → Settings → Environment Variables (Production). Bez tego produkcja nie pokaże logowania
# ani kart „Twój zakres”, a lokalnie z .env z VITE_REQUIRE_AUTH=true — wygląda jak inna aplikacja.

# Tylko do skryptu npm run test:slack — NIE prefixuj VITE_ (nie wklejaj webhooka do frontu).
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
